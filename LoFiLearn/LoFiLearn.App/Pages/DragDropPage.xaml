<Page
    x:Name="PageRoot"
    x:Class="LoFiLearn.App.Pages.DragDropPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LoFiLearn.Core.Models"
    Background="Transparent">

    <Grid Padding="24">
        <Border Style="{StaticResource LoFiCardStyle}" Shadow="{StaticResource CardShadow}">
            <StackPanel Spacing="20">
                <TextBlock x:Uid="DragDropPageHeader" Text="Drag & Drop" Style="{StaticResource TitleLargeStyle}" />
                <TextBlock x:Uid="DragDropPageSubheader" Text="Arrange ideas with playful drag routines." Style="{StaticResource BodyStyle}" />
                <Button x:Uid="DragDropPageAddButton" Content="Add task" Style="{StaticResource PrimaryPillButton}" Command="{x:Bind ViewModel.AddTaskCommand}" />
                <ListView ItemsSource="{x:Bind ViewModel.DragDropItems}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DragDropItem">
                            <Border Style="{StaticResource LoFiCardStyle}" Padding="16" Margin="0,0,0,12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{x:Bind Question}" Style="{StaticResource TitleMediumStyle}" />
                                    <TextBlock Text="{x:Bind Options.Count, Mode=OneWay}" Style="{StaticResource BodyStyle}" />
                                    <Button Content="Remove" Style="{StaticResource SecondaryPillButton}" Command="{x:Bind ViewModel.RemoveTaskCommand}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
