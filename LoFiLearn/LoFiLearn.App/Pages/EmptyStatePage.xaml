<Page
    x:Class="LoFiLearn.App.Pages.EmptyStatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel HorizontalAlignment="Center" Spacing="18">
            <Canvas Width="80" Height="80" Opacity="0.7">
                <Ellipse Width="80" Height="48" Fill="#FFF1E8" Canvas.Top="20" />
                <Path Data="M24,30 C24,24 32,24 32,30 C32,34 30,38 24,38 C18,38 16,34 16,30 Z" Fill="#DDB7A0" />
                <Path Data="M40,30 C40,24 48,24 48,30 C48,34 46,38 40,38 C34,38 32,34 32,30 Z" Fill="#DDB7A0" />
                <Path Data="M20,42 C22,50 28,54 32,54 C36,54 42,50 44,42" Stroke="#A67B5B" StrokeThickness="2" Fill="Transparent" />
            </Canvas>
            <TextBlock Text="📝 No items here yet" Style="{StaticResource TitleMediumStyle}" />
            <TextBlock Text="Start building a cozy study plan and your content will appear here." Style="{StaticResource EmptyStateText}" Width="320" />
        </StackPanel>
    </Grid>
</Page>
