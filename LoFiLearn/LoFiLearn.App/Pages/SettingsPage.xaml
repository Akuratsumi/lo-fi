<Page
    x:Name="PageRoot"
    x:Class="LoFiLearn.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="24">
        <Border Style="{StaticResource LoFiCardStyle}" Shadow="{StaticResource CardShadow}">
            <StackPanel Spacing="24">
                <TextBlock x:Uid="SettingsPageHeader" Text="Settings" Style="{StaticResource TitleLargeStyle}" />
                <TextBlock x:Uid="SettingsPageSubheader" Text="Customize theme, sound, and language in a warm, analog-inspired space." Style="{StaticResource BodyStyle}" />

                <StackPanel Spacing="12">
                    <TextBlock Text="Theme" Style="{StaticResource TitleMediumStyle}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableThemes}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                                <Button Style="{StaticResource ThemeSwatchStyle}" Content="{x:Bind .}" Command="{Binding DataContext.ViewModel.ApplyThemeCommand, ElementName=PageRoot}" CommandParameter="{x:Bind .}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Language" Style="{StaticResource TitleMediumStyle}" />
                    <ComboBox ItemsSource="{x:Bind ViewModel.AvailableLanguages}" SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}" />
                    <Button x:Uid="ApplyLanguageButton" Content="Apply language" Style="{StaticResource SecondaryPillButton}" Command="{x:Bind ViewModel.ApplyLanguageCommand}" />
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Sound" Style="{StaticResource TitleMediumStyle}" />
                    <Slider Minimum="0" Maximum="100" Value="{x:Bind ViewModel.Volume, Mode=TwoWay}" ValueChanged="OnVolumeChanged" />
                    <TextBlock Text="Volume" Style="{StaticResource BodyStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
