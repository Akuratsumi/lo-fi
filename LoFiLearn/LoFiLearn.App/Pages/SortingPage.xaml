<Page
    x:Name="PageRoot"
    x:Class="LoFiLearn.App.Pages.SortingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LoFiLearn.Core.Models"
    Background="Transparent">

    <Grid Padding="24">
        <Border Style="{StaticResource LoFiCardStyle}" Shadow="{StaticResource CardShadow}">
            <StackPanel Spacing="20">
                <TextBlock x:Uid="SortingPageHeader" Text="Sorting" Style="{StaticResource TitleLargeStyle}" />
                <TextBlock x:Uid="SortingPageSubheader" Text="Organize cards with calm sorting flows." Style="{StaticResource BodyStyle}" />
                <Button x:Uid="SortingPageAddButton" Content="Add batch" Style="{StaticResource PrimaryPillButton}" Command="{x:Bind ViewModel.AddBatchCommand}" />
                <ListView ItemsSource="{x:Bind ViewModel.SortingItems}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SortingItem">
                            <Border Style="{StaticResource LoFiCardStyle}" Padding="16" Margin="0,0,0,12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{x:Bind Label}" Style="{StaticResource TitleMediumStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Items count:" Style="{StaticResource BodyStyle}" />
                                        <TextBlock Text="{x:Bind Items.Count}" Style="{StaticResource BodyStyle}" />
                                    </StackPanel>
                                    <Button Content="Remove" Style="{StaticResource SecondaryPillButton}" Command="{x:Bind ViewModel.RemoveBatchCommand}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
