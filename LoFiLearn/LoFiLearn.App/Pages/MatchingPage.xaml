<Page
    x:Name="PageRoot"
    x:Class="LoFiLearn.App.Pages.MatchingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LoFiLearn.Core.Models"
    Background="Transparent">

    <Grid Padding="24">
        <Border Style="{StaticResource LoFiCardStyle}" Shadow="{StaticResource CardShadow}">
            <StackPanel Spacing="20">
                <TextBlock x:Uid="MatchingPageHeader" Text="Matching" Style="{StaticResource TitleLargeStyle}" />
                <TextBlock x:Uid="MatchingPageSubheader" Text="Connect pairs with a cozy matching experience." Style="{StaticResource BodyStyle}" />
                <Button x:Uid="MatchingPageAddButton" Content="Add set" Style="{StaticResource PrimaryPillButton}" Command="{x:Bind ViewModel.AddSetCommand}" />
                <ListView ItemsSource="{x:Bind ViewModel.MatchingItems}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MatchingItem">
                            <Border Style="{StaticResource LoFiCardStyle}" Padding="16" Margin="0,0,0,12">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Pair count:" Style="{StaticResource TitleMediumStyle}" />
                                        <TextBlock Text="{x:Bind Pairs.Count}" Style="{StaticResource BodyStyle}" />
                                    </StackPanel>
                                    <Button Content="Remove" Style="{StaticResource SecondaryPillButton}" Command="{x:Bind DataContext.ViewModel.RemoveSetCommand, ElementName=PageRoot}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
