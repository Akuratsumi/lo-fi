<Page
    x:Name="PageRoot"
    x:Class="LoFiLearn.App.Pages.SurveyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LoFiLearn.App.Pages"
    xmlns:viewmodels="using:LoFiLearn.App.ViewModels"
    xmlns:models="using:LoFiLearn.Core.Models"
    Background="Transparent">

    <Grid Padding="24">
        <Border Style="{StaticResource LoFiCardStyle}" Shadow="{StaticResource CardShadow}">
            <StackPanel Spacing="20">
                <TextBlock x:Uid="SurveyPageHeader" Text="Survey Builder" Style="{StaticResource TitleLargeStyle}" />
                <TextBlock x:Uid="SurveyPageSubheader" Text="Create warm, handwritten prompts for your study session." Style="{StaticResource BodyStyle}" />
                <Button x:Uid="SurveyPageAddButton" Content="Add question" Style="{StaticResource PrimaryPillButton}" Command="{x:Bind ViewModel.AddItemCommand}" />
                <ListView ItemsSource="{x:Bind ViewModel.SurveyItems}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SurveyItem" xmlns:models="using:LoFiLearn.Core.Models">
                            <Border Style="{StaticResource LoFiCardStyle}" Padding="16" Margin="0,0,0,12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{x:Bind Prompt}" Style="{StaticResource TitleMediumStyle}" />
                                    <TextBlock Text="{x:Bind Answer}" Style="{StaticResource BodyStyle}" />
                                    <Button Content="Remove" Style="{StaticResource SecondaryPillButton}" Command="{Binding DataContext.ViewModel.RemoveItemCommand, ElementName=PageRoot}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
